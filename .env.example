# Variables d'environnement

# Serveur
PORT=3000
NODE_ENV=development

# Base de données MySQL / MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=lan_party_manager
# Sur Linux avec MariaDB, le compte root utilise souvent l'authentification par
# socket unix plutôt qu'un mot de passe TCP. Dans ce cas, décommentez la ligne
# suivante (adaptez le chemin si nécessaire) et laissez DB_PASSWORD vide.
# DB_SOCKET_PATH=/var/run/mysqld/mysqld.sock

# JWT
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=24h

# Admin par défaut
ADMIN_EMAIL=admin@lanparty.local
ADMIN_PASSWORD=Admin@123
