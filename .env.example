# ============================================================
# Configuration de l'application - LAN Party Manager
# Copier ce fichier en .env et adapter les valeurs
# ============================================================

# --- Serveur ---
NODE_ENV=development
PORT=3000

# URL publique de l'application (utilisée pour les liens canoniques, meta og:url, logs)
# En production sans sous-répertoire : https://www.monsite.com  (sans slash final)
# En production avec sous-répertoire : https://www.monsite.com/app  (le chemin /app sera utilisé comme préfixe)
APP_URL=http://localhost:3000

# --- Base de données MySQL ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_database_password
DB_NAME=lan_party_manager

# --- Session ---
# Générer une clé secrète forte : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=change_this_to_a_very_long_random_secret_key

# --- Sécurité ---
# Durée de session en millisecondes (24h)
SESSION_DURATION=86400000

# Nombre maximum de tentatives de connexion avant blocage
LOGIN_RATE_LIMIT_MAX=10
# Fenêtre de temps pour le rate limit (15 minutes en ms)
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# --- Administration ---
# Identifiants du compte administrateur par défaut
# IMPORTANT : Changer immédiatement après la première connexion !
ADMIN_EMAIL=admin@lanparty.local
ADMIN_PASSWORD=Admin@LAN2024!
