<%- include('../partials/head') %>

<div class="error-page container">
  <div class="error-content">
    <div class="error-code"><%= typeof statusCode !== 'undefined' ? statusCode : 500 %></div>
    <h1 class="error-title"><%= typeof title !== 'undefined' ? title : 'Erreur serveur' %></h1>
    <p class="error-message"><%= typeof message !== 'undefined' ? message : 'Une erreur interne est survenue. Notre equipe a ete notifiee.' %></p>
    <a href="/" class="btn btn--primary btn--lg">
      <i class="fas fa-home"></i> Retour à l'accueil
    </a>
  </div>
</div>

<%- include('../partials/foot') %>
