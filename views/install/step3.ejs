<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | LAN Party Manager</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Rajdhani:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<main class="install-page">
  <div class="install-container">
    <div class="install-header">
      <img src="/images/logo.svg" alt="Logo" class="install-logo">
      <h1 class="install-title">LAN Party Manager</h1>
      <p class="install-subtitle">Assistant d'installation</p>
    </div>

    <div class="install-progress">
      <div class="progress-step done">✓</div>
      <div class="progress-line done"></div>
      <div class="progress-step done">✓</div>
      <div class="progress-line done"></div>
      <div class="progress-step active">3</div>
    </div>

    <div class="install-card">
      <h2>Étape 3 — Données de démonstration</h2>
      <p class="install-desc">Souhaitez-vous charger des données de démonstration (actualités et événements) pour commencer ?</p>

      <% if (errors && errors.length > 0) { %>
        <div class="form-errors">
          <% errors.forEach(e => { %><p>❌ <%= e.msg %></p><% }) %>
        </div>
      <% } %>

      <form action="/install/step3" method="POST" class="form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="seed-options">
          <label class="seed-option">
            <input type="radio" name="load_seeds" value="1" checked>
            <div class="seed-option-content">
              <span class="seed-icon">🌱</span>
              <div>
                <strong>Oui, charger les données de démo</strong>
                <p>5 actualités et 3 événements d'exemple pour démarrer rapidement</p>
              </div>
            </div>
          </label>

          <label class="seed-option">
            <input type="radio" name="load_seeds" value="0">
            <div class="seed-option-content">
              <span class="seed-icon">🔲</span>
              <div>
                <strong>Non, démarrer avec une base vide</strong>
                <p>Je créerai mon contenu moi-même depuis l'administration</p>
              </div>
            </div>
          </label>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary btn-lg">Finaliser l'installation →</button>
        </div>
      </form>
    </div>
  </div>
</main>

<script src="/js/main.js"></script>
</body>
</html>
