<%- include('../../partials/head') %>

<div class="container admin-container">
  <div class="admin-layout">
    <%- include('../_sidebar', { activeSection: 'rooms' }) %>

    <section class="admin-main">

  <div class="admin-header">
    <div>
      <h1 class="admin-title">
        <i class="fas fa-pen"></i> Modifier — <%= room.nom %>
      </h1>
    </div>
    <div class="admin-header-actions">
      <a href="/admin/rooms?event_id=<%= room.event_id %>" class="btn btn--ghost btn--sm">
        <i class="fas fa-arrow-left"></i> Retour aux salles
      </a>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <% if (errors.length > 0) { %>
        <div class="alert alert--error">
          <ul style="margin:0; padding-left:1.2rem;">
            <% errors.forEach(function(e) { %><li><%= e.msg %></li><% }); %>
          </ul>
        </div>
      <% } %>

      <form action="/admin/rooms/<%= room.id %>?_method=PUT" method="POST" class="form-grid">
        <input type="hidden" name="_csrf" value="<%= csrfToken() %>" />

        <div class="form-group">
          <label class="form-label">Événement</label>
          <p class="form-static">
            <i class="fas fa-calendar-days"></i>
            <%= events.find(e => e.id === room.event_id) ? events.find(e => e.id === room.event_id).nom : 'Événement #' + room.event_id %>
          </p>
        </div>

        <div class="form-group">
          <label class="form-label" for="nom">Nom de la salle <span class="required">*</span></label>
          <input type="text" id="nom" name="nom" class="form-input"
                 value="<%= old.nom || '' %>"
                 maxlength="100" required />
        </div>

        <div class="form-group">
          <label class="form-label" for="type">Type de salle <span class="required">*</span></label>
          <select id="type" name="type" class="form-select" required>
            <% TYPES_SALLE.forEach(function(t) { %>
              <option value="<%= t %>" <%= old.type === t ? 'selected' : '' %>>
                <%= t === 'simulation' ? 'Simulation' : 'Console' %>
              </option>
            <% }); %>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label" for="type_rencontre">Format supporté <span class="required">*</span></label>
          <select id="type_rencontre" name="type_rencontre" class="form-select" required>
            <% TYPES_RENCONTRE.forEach(function(t) { %>
              <option value="<%= t %>" <%= old.type_rencontre === t ? 'selected' : '' %>>
                <%= t === '2v2' ? '2v2 — Équipes (4 joueurs)' : t === '1v1' ? '1v1 — Face à face (2 joueurs)' : 'Solo — Un seul joueur' %>
              </option>
            <% }); %>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label">État</label>
          <label class="form-checkbox">
            <input type="checkbox" name="actif" value="1" <%= (old.actif == '1' || old.actif === 1) ? 'checked' : '' %> />
            Salle active
          </label>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn--primary">
            <i class="fas fa-save"></i> Enregistrer
          </button>
          <a href="/admin/rooms?event_id=<%= room.event_id %>" class="btn btn--ghost">Annuler</a>
        </div>
      </form>
    </div>
  </div>

    </section>
  </div>

</div>

<%- include('../../partials/foot') %>
