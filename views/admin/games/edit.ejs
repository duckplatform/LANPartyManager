<%- include('../../partials/head') %>

<div class="container admin-container">

  <div class="admin-header">
    <div>
      <h1 class="admin-title">
        <i class="fas fa-pen"></i> Modifier — <%= game.nom %>
      </h1>
    </div>
    <div class="admin-header-actions">
      <a href="/admin/games" class="btn btn--ghost btn--sm">
        <i class="fas fa-arrow-left"></i> Retour aux jeux
      </a>
    </div>
  </div>

  <div class="card">
    <div class="card-body">
      <% if (errors.length > 0) { %>
        <div class="alert alert--error">
          <ul style="margin:0; padding-left:1.2rem;">
            <% errors.forEach(function(e) { %><li><%= e.msg %></li><% }); %>
          </ul>
        </div>
      <% } %>

      <form action="/admin/games/<%= game.id %>?_method=PUT" method="POST" class="form-grid">
        <input type="hidden" name="_csrf" value="<%= csrfToken() %>" />

        <div class="form-group">
          <label class="form-label" for="nom">Nom du jeu <span class="required">*</span></label>
          <input type="text" id="nom" name="nom" class="form-input"
                 value="<%= old.nom || '' %>"
                 maxlength="100" required />
        </div>

        <div class="form-group">
          <label class="form-label" for="console">Console / Plateforme <span class="required">*</span></label>
          <input type="text" id="console" name="console" class="form-input"
                 value="<%= old.console || '' %>"
                 maxlength="100" required />
        </div>

        <div class="form-group">
          <label class="form-label" for="type_rencontre">Format de rencontre <span class="required">*</span></label>
          <select id="type_rencontre" name="type_rencontre" class="form-select" required>
            <% TYPES_RENCONTRE.forEach(function(t) { %>
              <option value="<%= t %>" <%= old.type_rencontre === t ? 'selected' : '' %>>
                <%= t === '1v1' ? '1v1 — Face à face (2 joueurs)' : '2v2 — Équipes (4 joueurs)' %>
              </option>
            <% }); %>
          </select>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn--primary">
            <i class="fas fa-save"></i> Enregistrer
          </button>
          <a href="/admin/games" class="btn btn--ghost">Annuler</a>
        </div>
      </form>
    </div>
  </div>

</div>

<%- include('../../partials/foot') %>
