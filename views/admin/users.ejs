<div class="admin-page">
  <div class="container">

    <div class="admin-header">
      <div>
        <h1><i class="fas fa-users-cog"></i> Gestion des utilisateurs</h1>
        <p><%= users.length %> membre(s) enregistré(s)</p>
      </div>
      <a href="<%= basePath %>/admin" class="btn btn-outline">
        <i class="fas fa-arrow-left"></i> Retour
      </a>
    </div>

    <!-- Alertes -->
    <% if (success && success.length > 0) { %>
      <div class="alert alert-success">
        <i class="fas fa-check-circle"></i>
        <% success.forEach(msg => { %><%= msg %><% }) %>
      </div>
    <% } %>
    <% if (errors && errors.length > 0) { %>
      <div class="alert alert-danger">
        <i class="fas fa-exclamation-triangle"></i>
        <ul class="error-list">
          <% errors.forEach(err => { %>
            <li><%= err %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <!-- Barre de recherche -->
    <div class="search-bar">
      <i class="fas fa-search"></i>
      <input type="text" id="userSearch" class="form-control" placeholder="Rechercher un utilisateur...">
    </div>

    <!-- Table des utilisateurs -->
    <div class="card">
      <div class="card-body p-0">
        <% if (users.length === 0) { %>
          <p class="text-muted text-center" style="padding: 2rem;">Aucun utilisateur trouvé.</p>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hoverable" id="usersTable">
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Pseudo</th>
                  <th>Nom complet</th>
                  <th>Email</th>
                  <th>Rôle</th>
                  <th>Inscrit le</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                <% users.forEach(u => { %>
                  <tr class="user-row">
                    <td><%= u.id %></td>
                    <td>
                      <div class="user-cell">
                        <div class="avatar-sm"><%= u.nickname.charAt(0).toUpperCase() %></div>
                        <strong><%= u.nickname %></strong>
                      </div>
                    </td>
                    <td><%= u.first_name %> <%= u.last_name %></td>
                    <td><%= u.email %></td>
                    <td>
                      <span class="badge badge-<%= u.role === 'admin' ? 'admin' : 'user' %>">
                        <i class="fas fa-<%= u.role === 'admin' ? 'shield-alt' : 'user' %>"></i>
                        <%= u.role === 'admin' ? 'Admin' : 'Membre' %>
                      </span>
                    </td>
                    <td><%= new Date(u.created_at).toLocaleDateString('fr-FR') %></td>
                    <td>
                      <div class="actions">
                        <a href="<%= basePath %>/admin/users/<%= u.id %>/edit" class="btn btn-sm btn-outline" title="Modifier">
                          <i class="fas fa-edit"></i>
                        </a>
                        <% if (u.id !== user.id) { %>
                          <form action="<%= basePath %>/admin/users/<%= u.id %>/delete" method="POST" style="display:inline;"
                            onsubmit="return confirm('Supprimer l\'utilisateur <%= u.nickname %> ?')">
                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                            <button type="submit" class="btn btn-sm btn-danger" title="Supprimer">
                              <i class="fas fa-trash"></i>
                            </button>
                          </form>
                        <% } %>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>

  </div>
</div>

<script>
// Recherche dynamique dans le tableau
document.getElementById('userSearch').addEventListener('input', function() {
  const q = this.value.toLowerCase();
  document.querySelectorAll('#usersTable .user-row').forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
  });
});
</script>
