<%- include('../../partials/head') %>

<div class="container admin-container">
  <div class="admin-layout">
    <%- include('../_sidebar', { activeSection: 'news' }) %>

    <section class="admin-main">

  <!-- En-tête admin -->
  <div class="admin-header">
    <div>
      <h1 class="admin-title">
        <i class="fas fa-newspaper"></i> Gestion des annonces
      </h1>
      <p class="admin-subtitle">Créez et gérez les annonces publiées sur le site.</p>
    </div>
    <div class="admin-header-actions">
      <a href="/admin" class="btn btn--ghost btn--sm">
        <i class="fas fa-arrow-left"></i> Tableau de bord
      </a>
      <a href="/admin/news/create" class="btn btn--primary btn--sm">
        <i class="fas fa-plus"></i> Nouvelle annonce
      </a>
    </div>
  </div>

  <!-- Tableau des annonces -->
  <div class="card admin-users-card">
    <div class="card-header admin-card-header">
      <h2><i class="fas fa-list"></i> Liste des annonces (<%= announcements.length %>)</h2>
    </div>
    <div class="card-body">
      <div class="table-responsive">
        <table class="data-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Titre</th>
              <th>Statut</th>
              <th>Date de création</th>
              <th>Dernière modification</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (announcements.length === 0) { %>
              <tr>
                <td colspan="6" class="table-empty">
                  <i class="fas fa-inbox"></i> Aucune annonce. <a href="/admin/news/create">Créer la première</a>
                </td>
              </tr>
            <% } else { %>
              <% announcements.forEach(function(a) { %>
                <tr>
                  <td class="td-id">#<%= a.id %></td>
                  <td>
                    <span class="news-title-cell">
                      <% if (a.statut === 'publie') { %>
                        <a href="/news/<%= a.id %>" class="link-muted" target="_blank" title="Voir sur le site">
                          <%= a.titre %>
                          <i class="fas fa-external-link-alt" style="font-size:0.7em;"></i>
                        </a>
                      <% } else { %>
                        <%= a.titre %>
                      <% } %>
                    </span>
                  </td>
                  <td>
                    <% if (a.statut === 'publie') { %>
                      <span class="badge badge--published"><i class="fas fa-check-circle"></i> Publié</span>
                    <% } else { %>
                      <span class="badge badge--draft"><i class="fas fa-pencil"></i> Brouillon</span>
                    <% } %>
                  </td>
                  <td class="td-date"><%= new Date(a.created_at).toLocaleDateString('fr-FR') %></td>
                  <td class="td-date"><%= new Date(a.updated_at).toLocaleDateString('fr-FR') %></td>
                  <td class="td-actions">
                    <!-- Modifier -->
                    <a href="/admin/news/<%= a.id %>/edit" class="btn btn--xs btn--info">
                      <i class="fas fa-edit"></i> Modifier
                    </a>
                    <!-- Supprimer -->
                    <form action="/admin/news/<%= a.id %>/delete" method="POST" class="inline-form">
                      <input type="hidden" name="_csrf" value="<%= csrfToken() %>" />
                      <button type="submit"
                              class="btn btn--xs btn--danger"
                              onclick="return confirm('Supprimer définitivement l\'annonce «\u00A0<%= a.titre %>\u00A0» ?')">
                        <i class="fas fa-trash"></i> Supprimer
                      </button>
                    </form>
                  </td>
                </tr>
              <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

    </section>
  </div>

</div>

<%- include('../../partials/foot') %>
