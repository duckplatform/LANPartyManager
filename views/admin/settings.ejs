<%- include('../partials/head') %>

<div class="container admin-container">
  <div class="admin-layout">
    <%- include('./_sidebar', { activeSection: 'settings' }) %>

    <section class="admin-main">

      <!-- En-tête -->
      <div class="admin-header">
        <div>
          <h1 class="admin-title">
            <i class="fas fa-sliders"></i> Paramètres de l'application
          </h1>
          <p class="admin-subtitle">
            Configurez l'identité et les intégrations de votre LANPartyManager.
          </p>
        </div>
      </div>

      <!-- Erreurs de validation -->
      <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
        <div class="form-errors">
          <% errors.forEach(function(e) { %>
            <p class="form-error-msg"><i class="fas fa-exclamation-circle"></i> <%= e.msg %></p>
          <% }); %>
        </div>
      <% } %>

      <!-- Formulaire -->
      <form action="/admin/settings" method="POST" class="news-form" novalidate>
        <input type="hidden" name="_csrf" value="<%= csrfToken() %>" />

        <div class="news-form-layout">

          <!-- ── Colonne principale ── -->
          <div class="news-form-main">

            <!-- Section Identité de l'association -->
            <div class="card" style="margin-bottom: var(--space-lg);">
              <div class="card-header">
                <h2><i class="fas fa-building"></i> Identité de l'association</h2>
              </div>
              <div class="card-body">

                <!-- Nom de l'association -->
                <div class="form-group">
                  <label class="form-label" for="organization_name">
                    <i class="fas fa-heading"></i> Nom de l'association
                  </label>
                  <input
                    type="text"
                    id="organization_name"
                    name="organization_name"
                    class="form-input"
                    placeholder="Ex. : LANPartyManager"
                    value="<%= (settings && settings.organization_name) ? settings.organization_name : 'LANPartyManager' %>"
                    maxlength="255"
                    required
                  />
                  <span class="form-hint">
                    Nom de votre association affiché sur toutes les pages publiques.
                  </span>
                </div>

                <!-- Slogan -->
                <div class="form-group">
                  <label class="form-label" for="organization_slogan">
                    <i class="fas fa-quote-left"></i> Slogan
                  </label>
                  <input
                    type="text"
                    id="organization_slogan"
                    name="organization_slogan"
                    class="form-input"
                    placeholder="Ex. : Le meilleur événement gaming de la région"
                    value="<%= (settings && settings.organization_slogan) ? settings.organization_slogan : '' %>"
                    maxlength="255"
                  />
                  <span class="form-hint">
                    Slogan ou tagline de votre association (affiché si configuré).
                  </span>
                </div>

                <!-- Logo -->
                <div class="form-group">
                  <label class="form-label" for="organization_logo">
                    <i class="fas fa-image"></i> Logo (URL)
                  </label>
                  <input
                    type="url"
                    id="organization_logo"
                    name="organization_logo"
                    class="form-input"
                    placeholder="Ex. : https://votre-domaine.com/logo.png"
                    value="<%= (settings && settings.organization_logo) ? settings.organization_logo : '' %>"
                    maxlength="500"
                  />
                  <span class="form-hint">
                    URL du logo de votre association. Format recommandé: PNG ou SVG, dimensions au moins 200x200px.
                    <% if (settings && settings.organization_logo) { %>
                      <div style="margin-top: var(--space-sm);">
                        <img src="<%= settings.organization_logo %>" alt="Logo" style="max-height: 60px; max-width: 200px; border: 1px solid var(--color-border); border-radius: 4px; padding: 4px;" />
                      </div>
                    <% } %>
                  </span>
                </div>

              </div>
            </div>

            <!-- Section Liens communautés -->
            <div class="card" style="margin-bottom: var(--space-lg);">
              <div class="card-header">
                <h2><i class="fas fa-share-alt"></i> Liens des communautés</h2>
              </div>
              <div class="card-body">
                <p class="form-hint" style="margin-bottom: var(--space-md);">
                  Configurez les liens de vos communautés pour qu'ils s'affichent sur le site.
                  Laissez vide pour masquer un lien.
                </p>

                <!-- Discord -->
                <div class="form-group">
                  <label class="form-label" for="community_link_discord">
                    <i class="fab fa-discord"></i> Discord
                  </label>
                  <input
                    type="url"
                    id="community_link_discord"
                    name="community_link_discord"
                    class="form-input"
                    placeholder="Ex. : https://discord.gg/invite-code"
                    value="<%= (settings && settings.community_link_discord) ? settings.community_link_discord : '' %>"
                    maxlength="500"
                  />
                  <span class="form-hint">
                    Lien d'invitation vers votre serveur Discord.
                  </span>
                </div>

                <!-- Twitter -->
                <div class="form-group">
                  <label class="form-label" for="community_link_twitter">
                    <i class="fab fa-twitter"></i> Twitter / X
                  </label>
                  <input
                    type="url"
                    id="community_link_twitter"
                    name="community_link_twitter"
                    class="form-input"
                    placeholder="Ex. : https://twitter.com/votre_compte"
                    value="<%= (settings && settings.community_link_twitter) ? settings.community_link_twitter : '' %>"
                    maxlength="500"
                  />
                  <span class="form-hint">
                    Lien vers votre profil Twitter/X.
                  </span>
                </div>

                <!-- Twitch -->
                <div class="form-group">
                  <label class="form-label" for="community_link_twitch">
                    <i class="fab fa-twitch"></i> Twitch
                  </label>
                  <input
                    type="url"
                    id="community_link_twitch"
                    name="community_link_twitch"
                    class="form-input"
                    placeholder="Ex. : https://www.twitch.tv/votre_canal"
                    value="<%= (settings && settings.community_link_twitch) ? settings.community_link_twitch : '' %>"
                    maxlength="500"
                  />
                  <span class="form-hint">
                    Lien vers votre chaîne Twitch.
                  </span>
                </div>

                <!-- YouTube -->
                <div class="form-group">
                  <label class="form-label" for="community_link_youtube">
                    <i class="fab fa-youtube"></i> YouTube
                  </label>
                  <input
                    type="url"
                    id="community_link_youtube"
                    name="community_link_youtube"
                    class="form-input"
                    placeholder="Ex. : https://www.youtube.com/@votre_chaine"
                    value="<%= (settings && settings.community_link_youtube) ? settings.community_link_youtube : '' %>"
                    maxlength="500"
                  />
                  <span class="form-hint">
                    Lien vers votre chaîne YouTube.
                  </span>
                </div>

                <!-- Website -->
                <div class="form-group">
                  <label class="form-label" for="community_link_website">
                    <i class="fas fa-globe"></i> Site web
                  </label>
                  <input
                    type="url"
                    id="community_link_website"
                    name="community_link_website"
                    class="form-input"
                    placeholder="Ex. : https://votre-association.com"
                    value="<%= (settings && settings.community_link_website) ? settings.community_link_website : '' %>"
                    maxlength="500"
                  />
                  <span class="form-hint">
                    Lien vers le site web officiel de votre association.
                  </span>
                </div>

              </div>
            </div>

            <!-- Section Discord -->
            <div class="card" style="margin-bottom: var(--space-lg);">
              <div class="card-header">
                <h2><i class="fab fa-discord"></i> Intégration Discord</h2>
              </div>
              <div class="card-body">

                <!-- Activer/désactiver Discord -->
                <div class="form-group">
                  <label class="form-label">
                    <i class="fas fa-toggle-on"></i> Activation globale Discord
                  </label>
                  <div style="display: flex; align-items: center; gap: var(--space-sm); margin-top: var(--space-xs);">
                    <input
                      type="checkbox"
                      id="discord_enabled"
                      name="discord_enabled"
                      value="1"
                      <%= (settings && settings.discord_enabled === '1') ? 'checked' : '' %>
                      style="width: 1.2rem; height: 1.2rem; cursor: pointer;"
                    />
                    <label for="discord_enabled" style="cursor: pointer; font-weight: normal;">
                      Activer les fonctionnalités Discord (notifications et connexion OAuth2)
                    </label>
                  </div>
                  <span class="form-hint">
                    Si désactivé, les notifications Discord et la connexion via Discord seront
                    complètement désactivées. Les options Discord des événements seront masquées.
                  </span>
                </div>

                <!-- Token bot -->
                <div class="form-group">
                  <label class="form-label" for="discord_bot_token">
                    <i class="fas fa-robot"></i> Token du bot Discord
                  </label>
                  <input
                    type="password"
                    id="discord_bot_token"
                    name="discord_bot_token"
                    class="form-input"
                    placeholder="<%= (settings && settings.discord_bot_token) ? '••••••••••••••••••••••••••••••••••' : 'Entrez le token du bot Discord…' %>"
                    maxlength="200"
                    autocomplete="off"
                  />
                  <span class="form-hint">
                    Token du bot Discord utilisé pour envoyer des notifications.
                    Laissez vide pour conserver la valeur actuelle.
                    <% if (settings && settings.discord_bot_token) { %>
                      <span style="color: var(--color-success);">
                        <i class="fas fa-check-circle"></i> Token configuré.
                      </span>
                    <% } else { %>
                      <span style="color: var(--color-warning);">
                        <i class="fas fa-exclamation-triangle"></i> Non configuré.
                      </span>
                    <% } %>
                  </span>
                </div>

                <!-- Canal actualités -->
                <div class="form-group">
                  <label class="form-label" for="discord_channel_news">
                    <i class="fas fa-newspaper"></i> ID canal Discord — Actualités
                  </label>
                  <input
                    type="text"
                    id="discord_channel_news"
                    name="discord_channel_news"
                    class="form-input"
                    placeholder="Ex. : 987654321098765432"
                    value="<%= (settings && settings.discord_channel_news) ? settings.discord_channel_news : '' %>"
                    maxlength="20"
                    inputmode="numeric"
                    pattern="[0-9]{17,20}"
                    autocomplete="off"
                  />
                  <span class="form-hint">
                    ID du canal Discord où seront publiées les notifications d'actualités.
                    Laissez vide pour désactiver les notifications d'actualités.
                  </span>
                </div>

                <hr style="border-color: var(--color-border); margin: var(--space-md) 0;" />

                <!-- OAuth2 Discord -->
                <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: var(--space-md);">
                  <i class="fas fa-key"></i> Connexion OAuth2 Discord
                </h3>
                <p class="form-hint" style="margin-bottom: var(--space-md);">
                  Permet aux membres de se connecter via leur compte Discord.
                  Nécessite une application Discord créée dans le
                  <a href="https://discord.com/developers/applications" target="_blank" rel="noopener noreferrer">Developer Portal</a>.
                </p>

                <!-- Client ID -->
                <div class="form-group">
                  <label class="form-label" for="discord_client_id">
                    <i class="fas fa-fingerprint"></i> Client ID
                  </label>
                  <input
                    type="text"
                    id="discord_client_id"
                    name="discord_client_id"
                    class="form-input"
                    placeholder="Ex. : 123456789012345678"
                    value="<%= (settings && settings.discord_client_id) ? settings.discord_client_id : '' %>"
                    maxlength="20"
                    inputmode="numeric"
                    pattern="[0-9]{17,20}"
                    autocomplete="off"
                  />
                  <span class="form-hint">
                    ID de l'application Discord (OAuth2 → General Information → Application ID).
                    <% if (settings && settings.discord_client_id) { %>
                      <span style="color: var(--color-success);">
                        <i class="fas fa-check-circle"></i> Configuré.
                      </span>
                    <% } %>
                  </span>
                </div>

                <!-- Client Secret -->
                <div class="form-group">
                  <label class="form-label" for="discord_client_secret">
                    <i class="fas fa-lock"></i> Client Secret
                  </label>
                  <input
                    type="password"
                    id="discord_client_secret"
                    name="discord_client_secret"
                    class="form-input"
                    placeholder="<%= (settings && settings.discord_client_secret) ? '••••••••••••••••••••••••••••••••' : 'Entrez le Client Secret…' %>"
                    maxlength="100"
                    autocomplete="off"
                  />
                  <span class="form-hint">
                    Secret de l'application Discord (OAuth2 → Client Information → Client Secret).
                    Laissez vide pour conserver la valeur actuelle.
                    <% if (settings && settings.discord_client_secret) { %>
                      <span style="color: var(--color-success);">
                        <i class="fas fa-check-circle"></i> Secret configuré.
                      </span>
                    <% } else { %>
                      <span style="color: var(--color-warning);">
                        <i class="fas fa-exclamation-triangle"></i> Non configuré.
                      </span>
                    <% } %>
                  </span>
                </div>

                <hr style="border-color: var(--color-border); margin: var(--space-md) 0;" />

                <!-- Slash Commands -->
                <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: var(--space-md);">
                  <i class="fas fa-terminal"></i> Commandes Slash Discord
                </h3>
                <p class="form-hint" style="margin-bottom: var(--space-md);">
                  Permet aux membres d'utiliser les commandes <code>/classement</code>, <code>/position</code>,
                  <code>/statistiques</code> et <code>/evenement</code> dans votre serveur Discord.
                  Nécessite la configuration de la <strong>Clé publique</strong> et de l'URL d'interaction
                  dans le <a href="https://discord.com/developers/applications" target="_blank" rel="noopener noreferrer">Developer Portal</a>.
                </p>

                <!-- Clé publique -->
                <div class="form-group">
                  <label class="form-label" for="discord_application_public_key">
                    <i class="fas fa-shield-alt"></i> Clé publique de l'application
                  </label>
                  <input
                    type="text"
                    id="discord_application_public_key"
                    name="discord_application_public_key"
                    class="form-input"
                    placeholder="Ex. : a1b2c3d4e5f6… (64 caractères hexadécimaux)"
                    value="<%= (settings && settings.discord_application_public_key) ? settings.discord_application_public_key : '' %>"
                    maxlength="64"
                    pattern="[0-9a-fA-F]{64}"
                    autocomplete="off"
                    style="font-family: monospace; font-size: 0.85rem;"
                  />
                  <span class="form-hint">
                    Clé publique Ed25519 (Discord Developer Portal → General Information → Public Key).
                    Utilisée pour vérifier les requêtes entrantes de Discord (interactions / slash commands).
                    <% if (settings && settings.discord_application_public_key) { %>
                      <span style="color: var(--color-success);">
                        <i class="fas fa-check-circle"></i> Clé configurée.
                      </span>
                    <% } else { %>
                      <span style="color: var(--color-warning);">
                        <i class="fas fa-exclamation-triangle"></i> Non configurée — les commandes slash ne fonctionneront pas.
                      </span>
                    <% } %>
                    <br>
                    URL d'interaction à renseigner dans Discord Developer Portal :<br>
                    <code style="font-size: 0.75rem; word-break: break-all;">
                      <%= appUrl || 'https://votre-domaine.example.com' %>/discord/interactions
                    </code>
                  </span>
                </div>

              </div>
            </div>

          </div>

          <!-- ── Barre latérale ── -->
          <aside class="news-form-sidebar">

            <!-- Actions -->
            <div class="card sidebar-card">
              <div class="card-header">
                <h2><i class="fas fa-save"></i> Enregistrer</h2>
              </div>
              <div class="card-body">
                <div class="form-actions">
                  <button type="submit" class="btn btn--primary btn--full">
                    <i class="fas fa-save"></i> Enregistrer
                  </button>
                </div>
                <div style="margin-top: var(--space-md); padding-top: var(--space-md); border-top: 1px solid var(--color-border);">
                  <a href="/admin" class="btn btn--ghost btn--full btn--sm">
                    <i class="fas fa-arrow-left"></i> Retour
                  </a>
                </div>
              </div>
            </div>

            <!-- Commandes Slash -->
            <div class="card sidebar-card">
              <div class="card-header">
                <h2><i class="fas fa-terminal"></i> Commandes Slash</h2>
              </div>
              <div class="card-body">
                <p style="font-size: 0.875rem; margin-bottom: var(--space-sm);">
                  Enregistrez les slash commands sur Discord pour qu'elles apparaissent
                  dans la liste des commandes de votre serveur.
                </p>
                <p style="font-size: 0.8rem; color: var(--color-text-muted); margin-bottom: var(--space-md);">
                  Commandes disponibles : <code>/classement</code>, <code>/position</code>,
                  <code>/statistiques</code>, <code>/evenement</code>
                </p>
                <% if (settings && settings.discord_client_id && (settings.discord_bot_token || process.env.DISCORD_BOT_TOKEN)) { %>
                  <form action="/admin/discord/register-commands" method="POST" style="margin: 0;">
                    <input type="hidden" name="_csrf" value="<%= csrfToken() %>" />
                    <button type="submit" class="btn btn--ghost btn--full btn--sm">
                      <i class="fab fa-discord"></i> Enreg. les commandes
                    </button>
                  </form>
                <% } else { %>
                  <p style="font-size: 0.8rem; color: var(--color-warning);">
                    <i class="fas fa-exclamation-triangle"></i>
                    Configurez d'abord le <strong>Client ID</strong> et le <strong>Token bot</strong>.
                  </p>
                <% } %>
              </div>
            </div>

            <!-- Guide Discord -->
            <div class="card sidebar-card">
              <div class="card-header">
                <h2><i class="fas fa-circle-info"></i> Guide Discord</h2>
              </div>
              <div class="card-body">
                <ol style="padding-left: var(--space-md); font-size: 0.875rem; line-height: 1.6;">
                  <li>Créez une application sur le <a href="https://discord.com/developers/applications" target="_blank" rel="noopener noreferrer">Discord Developer Portal</a></li>
                  <li>Copiez le <strong>Client ID</strong> et le <strong>Client Secret</strong></li>
                  <li>Ajoutez l'URI de redirection OAuth2 :<br>
                    <code style="font-size: 0.75rem; word-break: break-all;">
                      <%= appUrl || 'https://votre-domaine.example.com' %>/auth/discord/callback
                    </code>
                  </li>
                  <li>Créez un <strong>Bot</strong>, copiez son <strong>Token</strong></li>
                  <li>Copiez la <strong>Public Key</strong> (General Information)</li>
                  <li>Renseignez l'<strong>Interactions Endpoint URL</strong> :<br>
                    <code style="font-size: 0.75rem; word-break: break-all;">
                      <%= appUrl || 'https://votre-domaine.example.com' %>/discord/interactions
                    </code>
                  </li>
                  <li>Invitez le bot sur votre serveur Discord</li>
                  <li>Activez le <em>Mode développeur</em> dans Discord pour obtenir les IDs de canaux (Paramètres → Avancés → Mode développeur)</li>
                  <li>Cliquez sur <strong>Enregistrer les commandes</strong> dans la section « Commandes Slash »</li>
                </ol>
                <div style="margin-top: var(--space-sm);">
                  <a href="/admin/discord-test" class="btn btn--ghost btn--full btn--sm">
                    <i class="fab fa-discord"></i> Tester les notifications
                  </a>
                </div>
              </div>
            </div>

          </aside>

        </div>
      </form>

    </section>
  </div>
</div>

<%- include('../partials/foot') %>
