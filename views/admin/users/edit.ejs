<%- include('../../../partials/header') %>
<%- include('../../../partials/navbar') %>

<main class="admin-layout">
  <div class="admin-sidebar">
    <div class="sidebar-header"><span>⚙️ Admin Panel</span></div>
    <nav class="sidebar-nav">
      <a href="/admin/dashboard" class="sidebar-link">📊 Tableau de bord</a>
      <a href="/admin/news" class="sidebar-link">📰 Actualités</a>
      <a href="/admin/events" class="sidebar-link">🎮 Événements</a>
      <a href="/admin/users" class="sidebar-link active">👥 Utilisateurs</a>
      <hr class="sidebar-divider">
      <a href="/" class="sidebar-link">🏠 Site public</a>
    </nav>
  </div>

  <div class="admin-content">
    <%- include('../../../partials/flash') %>
    <div class="admin-header">
      <h1 class="admin-title">✏️ Modifier l'utilisateur</h1>
      <a href="/admin/users" class="btn btn-outline">← Retour</a>
    </div>

    <div class="profile-card" style="margin-bottom:2rem;">
      <div class="profile-info">
        <div class="profile-avatar"><span><%= editUser.username.charAt(0).toUpperCase() %></span></div>
        <div class="profile-details">
          <h2><%= editUser.username %></h2>
          <p class="text-muted"><%= editUser.email %></p>
        </div>
      </div>
    </div>

    <% if (errors && errors.length > 0) { %>
      <div class="form-errors">
        <% errors.forEach(e => { %><p>❌ <%= e.msg %></p><% }) %>
      </div>
    <% } %>

    <div class="admin-form-card">
      <form action="/admin/users/<%= editUser.id %>/edit" method="POST" class="form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="form-group">
          <label class="form-label">Rôle</label>
          <select name="role" class="form-input form-select">
            <option value="user" <%= editUser.role === 'user' ? 'selected' : '' %>>Utilisateur</option>
            <option value="moderator" <%= editUser.role === 'moderator' ? 'selected' : '' %>>Modérateur</option>
            <option value="admin" <%= editUser.role === 'admin' ? 'selected' : '' %>>Administrateur</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label">Statut</label>
          <select name="is_active" class="form-input form-select">
            <option value="1" <%= editUser.is_active ? 'selected' : '' %>>Actif</option>
            <option value="0" <%= !editUser.is_active ? 'selected' : '' %>>Inactif</option>
          </select>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Enregistrer</button>
          <a href="/admin/users" class="btn btn-outline">Annuler</a>
        </div>
      </form>
    </div>
  </div>
</main>

<%- include('../../../partials/footer') %>
