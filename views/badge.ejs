<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | LANPartyManager</title>

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;700;900&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/badge.css" />
  <!-- html2canvas : capture badge → image/PDF (fallback iOS) -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"
          integrity="sha512-BNaRQnYJYiPSqHHDb58B0yaPfCu+Wgds8Gp/gU33kqBtgNS4tSPHuGibyoeqMV/TJlSKda6FXzoEyYGjTe+vXA=="
          crossorigin="anonymous" referrerpolicy="no-referrer"></script>
</head>
<body class="page-badge">

  <!-- Barre d'actions (masquée à l'impression) -->
  <div class="badge-actions no-print">
    <a href="/profile" class="btn btn--ghost btn--sm">
      <i class="fas fa-arrow-left"></i> Retour au profil
    </a>
    <button id="btnPdf" class="btn btn--primary btn--sm">
      <i class="fas fa-print"></i> Imprimer / Sauvegarder en PDF
    </button>
  </div>

  <!-- Badge électronique -->
  <div class="badge-wrapper">
    <div class="badge-card">

      <!-- En-tête du badge -->
      <div class="badge-header">
        <div class="badge-logo">
          <i class="fas fa-gamepad"></i>
          <span>LAN<span class="badge-logo-accent">Party</span>Manager</span>
        </div>
        <div class="badge-tag">BADGE MEMBRE</div>
      </div>

      <!-- Bloc événement supprimé : le badge est propre au membre, pas à un événement -->

      <!-- Séparateur -->
      <div class="badge-divider">
        <span class="badge-divider-dot"></span>
        <span class="badge-divider-line"></span>
        <span class="badge-divider-dot"></span>
      </div>

      <!-- Infos membre + QR Code -->
      <div class="badge-body">
        <div class="badge-player">
          <div class="badge-player-avatar">
            <i class="fas fa-circle-user"></i>
          </div>
          <div class="badge-player-info">
            <div class="badge-player-pseudo"><%= user.pseudo %></div>
            <div class="badge-player-name"><%= user.prenom %> <%= user.nom %></div>
            <div class="badge-player-role">
              <% if (user.is_admin) { %>
                <span class="badge-role badge-role--admin"><i class="fas fa-shield-halved"></i> Administrateur</span>
              <% } else if (user.is_moderator) { %>
                <span class="badge-role badge-role--moderator"><i class="fas fa-user-shield"></i> Modérateur</span>
              <% } else { %>
                <span class="badge-role badge-role--member"><i class="fas fa-user"></i> Membre</span>
              <% } %>
            </div>
          </div>
        </div>

        <div class="badge-qr">
          <img src="<%= qrDataUrl %>" alt="QR Code badge membre" class="badge-qr-img" />
          <p class="badge-qr-hint">Scanner à l'entrée</p>
        </div>
      </div>

      <!-- Pied du badge -->
      <div class="badge-footer">
        <div class="badge-id">
          <span class="badge-id-label">ID Membre</span>
          <span class="badge-id-value"><%= user.badge_token %></span>
        </div>
        <div class="badge-registered-date">
          <span>Membre depuis <%= new Date(user.created_at).toLocaleDateString('fr-FR') %></span>
        </div>
      </div>

    </div>
  </div>

<script>
(function () {
  /* Détecte iOS Safari (window.print désactivé sur iOS) */
  const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;

  document.getElementById('btnPdf').addEventListener('click', function () {
    if (!isIOS) {
      /* Desktop / Android Chrome : impression native → Enregistrer en PDF */
      window.print();
      return;
    }

    /* iOS : capture la carte via html2canvas puis partage ou ouvre en image */
    var btn = this;
    btn.disabled = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Génération…';

    var card = document.querySelector('.badge-card');

    html2canvas(card, {
      backgroundColor: '#1e293b',
      scale: 2,               /* résolution x2 pour les écrans Retina */
      useCORS: true,
      logging: false
    }).then(function (canvas) {
      canvas.toBlob(function (blob) {
        var file = new File([blob], 'badge-lan.png', { type: 'image/png' });

        /* Web Share API niveau 2 (fichiers) — disponible sur iOS 15+ */
        if (navigator.canShare && navigator.canShare({ files: [file] })) {
          navigator.share({
            title: document.title,
            files: [file]
          }).catch(function () { /* annulé par l'utilisateur */ });
        } else {
          /* Fallback : ouvrir l'image dans un nouvel onglet → Appui long → Enregistrer */
          var url = URL.createObjectURL(blob);
          var a = document.createElement('a');
          a.href = url;
          a.download = 'badge-lan.png';
          a.click();
          setTimeout(function () { URL.revokeObjectURL(url); }, 3000);
        }

        btn.disabled = false;
        btn.innerHTML = '<i class="fas fa-print"></i> Imprimer / Sauvegarder en PDF';
      }, 'image/png');
    }).catch(function (err) {
      console.error('[Badge] html2canvas error :', err);
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-print"></i> Imprimer / Sauvegarder en PDF';
      alert('Impossible de générer le badge. Essayez via Partager > Enregistrer l\'image depuis votre navigateur.');
    });
  });
}());
</script>
</body>
</html>
