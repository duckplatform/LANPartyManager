<%- include('../partials/head') %>

<div class="auth-container">
  <div class="auth-card">
    <!-- En-tête -->
    <div class="auth-card-header">
      <div class="auth-icon">
        <i class="fas fa-user-plus"></i>
      </div>
      <h1 class="auth-title">Inscription</h1>
      <p class="auth-subtitle">Rejoignez notre communauté gaming</p>
    </div>

    <!-- Erreurs de validation -->
    <% if (errors && errors.length > 0) { %>
      <div class="form-errors" role="alert">
        <% errors.forEach(function(err) { %>
          <p class="form-error-msg"><i class="fas fa-triangle-exclamation"></i> <%= err.msg %></p>
        <% }); %>
      </div>
    <% } %>

    <!-- Formulaire d'inscription -->
    <form action="/auth/register" method="POST" class="auth-form" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken() %>" />

      <div class="form-row">
        <div class="form-group">
          <label for="nom" class="form-label">
            <i class="fas fa-id-card"></i> Nom
          </label>
          <input
            type="text"
            id="nom"
            name="nom"
            class="form-input"
            value="<%= old.nom || '' %>"
            placeholder="Dupont"
            required
            autocomplete="family-name"
            maxlength="100"
          />
        </div>

        <div class="form-group">
          <label for="prenom" class="form-label">
            <i class="fas fa-id-card"></i> Prénom
          </label>
          <input
            type="text"
            id="prenom"
            name="prenom"
            class="form-input"
            value="<%= old.prenom || '' %>"
            placeholder="Jean"
            required
            autocomplete="given-name"
            maxlength="100"
          />
        </div>
      </div>

      <div class="form-group">
        <label for="pseudo" class="form-label">
          <i class="fas fa-gamepad"></i> Pseudo (surnom en jeu)
        </label>
        <input
          type="text"
          id="pseudo"
          name="pseudo"
          class="form-input"
          value="<%= old.pseudo || '' %>"
          placeholder="ProGamer42"
          required
          minlength="2"
          maxlength="50"
          autocomplete="nickname"
        />
        <small class="form-hint">2 à 50 caractères, lettres, chiffres, tirets et espaces.</small>
      </div>

      <div class="form-group">
        <label for="email" class="form-label">
          <i class="fas fa-envelope"></i> Adresse e-mail
        </label>
        <input
          type="email"
          id="email"
          name="email"
          class="form-input"
          value="<%= old.email || '' %>"
          placeholder="votre@email.com"
          required
          autocomplete="email"
        />
      </div>

      <div class="form-group">
        <label for="password" class="form-label">
          <i class="fas fa-lock"></i> Mot de passe
        </label>
        <div class="input-password-wrap">
          <input
            type="password"
            id="password"
            name="password"
            class="form-input"
            placeholder="••••••••"
            required
            minlength="8"
            autocomplete="new-password"
          />
          <button type="button" class="password-toggle" aria-label="Afficher/masquer le mot de passe">
            <i class="fas fa-eye"></i>
          </button>
        </div>
        <small class="form-hint">Minimum 8 caractères, une majuscule et un chiffre.</small>
      </div>

      <div class="form-group">
        <label for="password_confirm" class="form-label">
          <i class="fas fa-lock"></i> Confirmer le mot de passe
        </label>
        <div class="input-password-wrap">
          <input
            type="password"
            id="password_confirm"
            name="password_confirm"
            class="form-input"
            placeholder="••••••••"
            required
            autocomplete="new-password"
          />
          <button type="button" class="password-toggle" aria-label="Afficher/masquer le mot de passe">
            <i class="fas fa-eye"></i>
          </button>
        </div>
      </div>

      <button type="submit" class="btn btn--primary btn--full">
        <i class="fas fa-user-plus"></i> Créer mon compte
      </button>
    </form>

    <% if (discordEnabled) { %>
      <!-- Séparateur -->
      <div class="auth-divider">
        <span>ou</span>
      </div>

      <!-- Inscription via Discord -->
      <a href="/auth/discord" class="btn btn--discord btn--full">
        <i class="fab fa-discord"></i> S'inscrire avec Discord
      </a>
    <% } %>

    <!-- Lien vers la connexion -->
    <div class="auth-switch">
      <p>Déjà membre ? <a href="/auth/login" class="link-accent">Se connecter</a></p>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>
