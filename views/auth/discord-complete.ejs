<%- include('../partials/head') %>

<div class="auth-container">
  <div class="auth-card">
    <!-- En-tête -->
    <div class="auth-card-header">
      <div class="auth-icon auth-icon--discord">
        <i class="fab fa-discord"></i>
      </div>
      <h1 class="auth-title">Finaliser l'inscription</h1>
      <p class="auth-subtitle">Votre compte Discord est connecté. Complétez vos informations pour rejoindre la communauté.</p>
    </div>

    <!-- Erreurs de validation -->
    <% if (errors && errors.length > 0) { %>
      <div class="form-errors" role="alert">
        <% errors.forEach(function(err) { %>
          <p class="form-error-msg"><i class="fas fa-triangle-exclamation"></i> <%= err.msg %></p>
        <% }); %>
      </div>
    <% } %>

    <!-- Formulaire de complétion -->
    <form action="/auth/discord/complete" method="POST" class="auth-form" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken() %>" />

      <div class="form-row">
        <div class="form-group">
          <label for="nom" class="form-label">
            <i class="fas fa-id-card"></i> Nom
          </label>
          <input
            type="text"
            id="nom"
            name="nom"
            class="form-input"
            value="<%= old.nom || '' %>"
            placeholder="Dupont"
            required
            autocomplete="family-name"
            maxlength="100"
          />
        </div>

        <div class="form-group">
          <label for="prenom" class="form-label">
            <i class="fas fa-id-card"></i> Prénom
          </label>
          <input
            type="text"
            id="prenom"
            name="prenom"
            class="form-input"
            value="<%= old.prenom || '' %>"
            placeholder="Jean"
            required
            autocomplete="given-name"
            maxlength="100"
          />
        </div>
      </div>

      <div class="form-group">
        <label for="pseudo" class="form-label">
          <i class="fas fa-gamepad"></i> Pseudo (surnom en jeu)
        </label>
        <input
          type="text"
          id="pseudo"
          name="pseudo"
          class="form-input"
          value="<%= old.pseudo || '' %>"
          placeholder="ProGamer42"
          required
          minlength="2"
          maxlength="50"
          autocomplete="nickname"
        />
        <small class="form-hint">2 à 50 caractères, lettres, chiffres, tirets et espaces.</small>
      </div>

      <div class="form-group">
        <label for="email" class="form-label">
          <i class="fas fa-envelope"></i> Adresse e-mail
        </label>
        <input
          type="email"
          id="email"
          name="email"
          class="form-input"
          value="<%= old.email || '' %>"
          placeholder="votre@email.com"
          required
          autocomplete="email"
        />
        <small class="form-hint">Utilisée uniquement pour vous contacter, non visible publiquement.</small>
      </div>

      <button type="submit" class="btn btn--discord btn--full">
        <i class="fab fa-discord"></i> Créer mon compte
      </button>
    </form>

    <!-- Lien retour -->
    <div class="auth-switch">
      <p>Annuler ? <a href="/auth/register" class="link-accent">Retour à l'inscription</a></p>
    </div>
  </div>
</div>

<%- include('../partials/foot') %>
