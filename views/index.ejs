<%- include('partials/head') %>

<!-- ═══════════════════ HERO ═══════════════════ -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="container hero-content">
    <div class="hero-badge">
      <span><i class="fas fa-bolt"></i> Association Gaming</span>
    </div>
    <h1 class="hero-title">
      Rejoignez la<br />
      <span class="text-gradient">LAN Party</span><br />
      ultime
    </h1>
    <p class="hero-subtitle">
      Compétitions, soirées gaming, tournois et bien plus encore.
      Rejoignez notre communauté de passionnés !
    </p>
    <div class="hero-actions">
      <% if (!currentUser) { %>
        <a href="/auth/register" class="btn btn--primary btn--lg">
          <i class="fas fa-user-plus"></i> Nous rejoindre
        </a>
        <a href="/auth/login" class="btn btn--ghost btn--lg">
          <i class="fas fa-right-to-bracket"></i> Connexion
        </a>
      <% } else { %>
        <a href="/profile" class="btn btn--primary btn--lg">
          <i class="fas fa-user"></i> Mon profil
        </a>
      <% } %>
    </div>
  </div>
  <div class="hero-scroll-indicator" aria-hidden="true">
    <i class="fas fa-chevron-down"></i>
  </div>
</section>

<!-- ═══════════════════ ÉVÉNEMENT ACTIF ═══════════════════ -->
<% if (activeEvent) { %>
<section class="section event-highlight-section">
  <div class="container">
    <div class="event-highlight-card">
      <div class="event-highlight-badge">
        <% if (eventIsLive) { %>
          <span class="event-status-badge event-status--live">
            <i class="fas fa-circle-play"></i> En cours
          </span>
        <% } else { %>
          <span class="event-status-badge event-status--upcoming">
            <i class="fas fa-calendar-check"></i> Prochain événement
          </span>
        <% } %>
      </div>

      <div class="event-highlight-body">
        <div class="event-highlight-info">
          <h2 class="event-highlight-title">
            <i class="fas fa-gamepad"></i> <%= activeEvent.nom %>
          </h2>
          <div class="event-highlight-meta">
            <span>
              <i class="fas fa-calendar-alt"></i>
              <%= new Date(activeEvent.date_heure).toLocaleDateString('fr-FR', {
                weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
              }) %>
              à
              <%= new Date(activeEvent.date_heure).toLocaleTimeString('fr-FR', {
                hour: '2-digit', minute: '2-digit'
              }) %>
            </span>
            <span>
              <i class="fas fa-location-dot"></i> <%= activeEvent.lieu %>
            </span>
            <span>
              <i class="fas fa-users"></i> <%= registrationCount %> inscrit<%= registrationCount !== 1 ? 's' : '' %>
            </span>
          </div>

          <!-- Chrono inscriptions -->
          <% if (registrationOpen) { %>
            <div class="event-countdown-wrap">
              <p class="event-countdown-label">
                <i class="fas fa-hourglass-half"></i> Inscriptions ouvertes — fermeture dans :
              </p>
              <div class="event-countdown" id="eventCountdown"
                   data-deadline="<%= registrationDeadlineISO %>">
                <div class="countdown-unit"><span class="countdown-num" id="cd-days">--</span><span class="countdown-lbl">jours</span></div>
                <span class="countdown-sep">:</span>
                <div class="countdown-unit"><span class="countdown-num" id="cd-hours">--</span><span class="countdown-lbl">heures</span></div>
                <span class="countdown-sep">:</span>
                <div class="countdown-unit"><span class="countdown-num" id="cd-minutes">--</span><span class="countdown-lbl">min</span></div>
                <span class="countdown-sep">:</span>
                <div class="countdown-unit"><span class="countdown-num" id="cd-seconds">--</span><span class="countdown-lbl">sec</span></div>
              </div>
            </div>
          <% } else { %>
            <p class="event-registrations-closed">
              <i class="fas fa-lock"></i> Les inscriptions sont closes.
            </p>
          <% } %>
        </div>

        <!-- Actions -->
        <div class="event-highlight-actions">
          <% if (!currentUser) { %>
            <a href="/auth/register" class="btn btn--primary">
              <i class="fas fa-user-plus"></i> Créer un compte pour s'inscrire
            </a>
          <% } else if (isRegistered) { %>
            <div class="event-registered-badge">
              <i class="fas fa-circle-check"></i> Vous êtes inscrit !
            </div>
            <% if (registrationOpen) { %>
              <form action="/profile/events/<%= activeEvent.id %>/unregister" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken() %>" />
                <button type="submit" class="btn btn--ghost btn--sm"
                        onclick="return confirm('Annuler votre inscription ?')">
                  <i class="fas fa-user-minus"></i> Se désinscrire
                </button>
              </form>
            <% } %>
          <% } else if (registrationOpen) { %>
            <form action="/profile/events/<%= activeEvent.id %>/register" method="POST">
              <input type="hidden" name="_csrf" value="<%= csrfToken() %>" />
              <button type="submit" class="btn btn--primary">
                <i class="fas fa-user-plus"></i> S'inscrire à l'événement
              </button>
            </form>
          <% } else { %>
            <p class="text-muted">
              <i class="fas fa-lock"></i> Inscriptions closes.
            </p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
/* ── Compte à rebours inscriptions ── */
(function () {
  'use strict';
  const el = document.getElementById('eventCountdown');
  if (!el) return;

  const deadline = new Date(el.dataset.deadline).getTime();

  function pad(n) { return String(n).padStart(2, '0'); }

  function tick() {
    const diff = deadline - Date.now();
    if (diff <= 0) {
      el.innerHTML = '<span class="event-registrations-closed"><i class="fas fa-lock"></i> Inscriptions closes</span>';
      return;
    }
    const days    = Math.floor(diff / 86400000);
    const hours   = Math.floor((diff % 86400000) / 3600000);
    const minutes = Math.floor((diff % 3600000)  / 60000);
    const seconds = Math.floor((diff % 60000)    / 1000);

    document.getElementById('cd-days').textContent    = days;
    document.getElementById('cd-hours').textContent   = pad(hours);
    document.getElementById('cd-minutes').textContent = pad(minutes);
    document.getElementById('cd-seconds').textContent = pad(seconds);

    setTimeout(tick, 1000);
  }
  tick();
})();
</script>
<% } %>

<!-- ═══════════════════ CLASSEMENT ═══════════════════ -->
<% if (activeEvent && typeof eventRanking !== 'undefined' && eventRanking && eventRanking.length > 0) { %>
<section class="section ranking-section">
  <div class="container">
    <div class="ranking-card">
      <div class="ranking-header">
        <h2><i class="fas fa-trophy"></i> Classement Live</h2>
        <p class="ranking-subtitle">Solo = 1pt • 1v1 = 2pts • 2v2 = 3pts</p>
      </div>
      <div class="ranking-body">
        <div style="overflow-x:auto;">
          <table class="ranking-table">
            <thead>
              <tr>
                <th class="ranking-col-rank">Rang</th>
                <th class="ranking-col-player">Joueur</th>
                <th class="ranking-col-points"><i class="fas fa-star"></i> Points</th>
                <th class="ranking-col-wins"><i class="fas fa-circle-check"></i> Victoires</th>
                <th class="ranking-col-battles"><i class="fas fa-gamepad"></i> Rencontres</th>
              </tr>
            </thead>
            <tbody>
              <% eventRanking.forEach(function(entry) { %>
              <tr class="ranking-row<% if (entry.rang === 1) { %> ranking-row--gold<% } else if (entry.rang === 2) { %> ranking-row--silver<% } else if (entry.rang === 3) { %> ranking-row--bronze<% } %>">
                <td class="ranking-cell ranking-cell-rank">
                  <div class="rank-badge">
                    <% if (entry.rang === 1) { %><i class="fas fa-medal" style="color:#facc15;"></i><% } else if (entry.rang === 2) { %><i class="fas fa-medal" style="color:#d1d5db;"></i><% } else if (entry.rang === 3) { %><i class="fas fa-medal" style="color:#d97706;"></i><% } else { %><span><%= entry.rang %></span><% } %>
                  </div>
                </td>
                <td class="ranking-cell ranking-cell-player">
                  <span class="player-name"><%= entry.pseudo %></span>
                </td>
                <td class="ranking-cell ranking-cell-points">
                  <span class="badge badge-points"><%= entry.points %> pts</span>
                </td>
                <td class="ranking-cell ranking-cell-wins">
                  <span class="badge badge-wins"><%= entry.wins %></span>
                </td>
                <td class="ranking-cell ranking-cell-battles">
                  <span class="badge badge-battles"><%= entry.battles_played %></span>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.ranking-section { padding: var(--space-lg) 0; }
.ranking-card {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border);
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
}
.ranking-header {
  background: linear-gradient(135deg, var(--color-primary) 0%, rgba(59, 130, 246, 0.8) 100%);
  padding: var(--space-md) var(--space-lg);
  color: white;
}
.ranking-header h2 {
  font-size: 1.65rem;
  margin-bottom: 0.25rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.ranking-subtitle {
  font-size: 0.92rem;
  opacity: 0.9;
  margin-top: 0.5rem;
  letter-spacing: 0.02em;
}
.ranking-body {
  padding: var(--space-lg);
}
.ranking-table {
  width: 100%;
  border-collapse: collapse;
}
.ranking-table thead {
  background: rgba(59, 130, 246, 0.05);
  border-bottom: 2px solid var(--color-border);
}
.ranking-table th {
  padding: 1rem var(--space-md);
  text-align: left;
  font-size: 0.88rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--color-text-muted);
}
.ranking-table tbody tr {
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  transition: all 0.2s ease;
}
.ranking-table tbody tr:hover {
  background: rgba(59, 130, 246, 0.08);
}
.ranking-row--gold { background: rgba(250, 204, 21, 0.08); }
.ranking-row--gold:hover { background: rgba(250, 204, 21, 0.12); }
.ranking-row--silver { background: rgba(209, 213, 219, 0.06); }
.ranking-row--silver:hover { background: rgba(209, 213, 219, 0.1); }
.ranking-row--bronze { background: rgba(217, 119, 6, 0.06); }
.ranking-row--bronze:hover { background: rgba(217, 119, 6, 0.1); }
.ranking-cell {
  padding: 1.2rem var(--space-md);
  vertical-align: middle;
}
.ranking-cell-rank { width: 70px; }
.rank-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(59, 130, 246, 0.05));
  border: 2px solid rgba(59, 130, 246, 0.3);
  font-weight: 700;
  font-size: 1rem;
  color: var(--color-primary);
}
.ranking-row--gold .rank-badge {
  background: linear-gradient(135deg, rgba(250, 204, 21, 0.2), rgba(250, 204, 21, 0.1));
  border-color: rgba(250, 204, 21, 0.4);
  color: #facc15;
}
.ranking-row--silver .rank-badge {
  background: linear-gradient(135deg, rgba(209, 213, 219, 0.2), rgba(209, 213, 219, 0.1));
  border-color: rgba(209, 213, 219, 0.4);
  color: #d1d5db;
}
.ranking-row--bronze .rank-badge {
  background: linear-gradient(135deg, rgba(217, 119, 6, 0.2), rgba(217, 119, 6, 0.1));
  border-color: rgba(217, 119, 6, 0.4);
  color: #d97706;
}
.player-name {
  font-weight: 600;
  font-size: 1.05rem;
}
.badge {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.4rem 0.85rem;
  border-radius: 999px;
  font-size: 0.9rem;
  font-weight: 600;
  letter-spacing: 0.01em;
}
.badge-points {
  background: rgba(59, 130, 246, 0.15);
  color: #3b82f6;
  border: 1px solid rgba(59, 130, 246, 0.3);
}
.badge-wins {
  background: rgba(34, 197, 94, 0.15);
  color: #22c55e;
  border: 1px solid rgba(34, 197, 94, 0.3);
}
.badge-battles {
  background: rgba(168, 85, 247, 0.15);
  color: #a855f7;
  border: 1px solid rgba(168, 85, 247, 0.3);
}
@media (max-width: 768px) {
  .ranking-header h2 { font-size: 1.35rem; }
  .ranking-table th, .ranking-cell { padding: 0.75rem 0.5rem; }
  .ranking-col-rank, .ranking-col-battles { display: none; }
  .rank-badge { width: 36px; height: 36px; }
}
</style>
<% } %>

<!-- ═══════════════════ FEATURES ═══════════════════ -->
<section class="section features-section">
  <div class="container">
    <h2 class="section-title text-center">
      Pourquoi nous rejoindre ?
    </h2>
    <div class="features-grid">
      <article class="feature-card">
        <div class="feature-icon">
          <i class="fas fa-trophy"></i>
        </div>
        <h3>Tournois</h3>
        <p>Participez à des tournois organisés régulièrement sur vos jeux favoris.</p>
      </article>

      <article class="feature-card">
        <div class="feature-icon">
          <i class="fas fa-users"></i>
        </div>
        <h3>Communauté</h3>
        <p>Rejoignez des centaines de gamers passionnés et faites-vous de nouveaux amis.</p>
      </article>

      <article class="feature-card">
        <div class="feature-icon">
          <i class="fas fa-calendar-days"></i>
        </div>
        <h3>Événements</h3>
        <p>LAN parties, soirées gaming et rassemblements tout au long de l'année.</p>
      </article>

      <article class="feature-card">
        <div class="feature-icon">
          <i class="fas fa-headset"></i>
        </div>
        <h3>Support</h3>
        <p>Une équipe dédiée pour vous accompagner dans tous vos besoins gaming.</p>
      </article>
    </div>
  </div>
</section>

<!-- ═══════════════════ CTA ═══════════════════ -->
<% if (!currentUser) { %>
<section class="section cta-section">
  <div class="container cta-inner">
    <div class="cta-content">
      <h2>Prêt à rejoindre l'aventure ?</h2>
      <p>Créez votre compte gratuitement et accédez à tous nos événements.</p>
    </div>
    <a href="/auth/register" class="btn btn--primary btn--lg">
      <i class="fas fa-gamepad"></i> Commencer maintenant
    </a>
  </div>
</section>
<% } %>

<!-- ═══════════════════ DERNIÈRES ANNONCES ═══════════════════ -->
<% if (latestAnnouncements && latestAnnouncements.length > 0) { %>
<section class="section news-home-section">
  <div class="container">
    <div class="news-home-header">
      <h2 class="section-title">
        <i class="fas fa-newspaper"></i> Dernières actualités
      </h2>
      <a href="/news" class="btn btn--ghost btn--sm news-all-link">
        Toutes les actualités <i class="fas fa-arrow-right"></i>
      </a>
    </div>
    <div class="news-home-grid">
      <% latestAnnouncements.forEach(function(a) { %>
        <article class="news-home-card">
          <div class="news-card-meta">
            <span class="news-card-date">
              <i class="fas fa-calendar-alt"></i>
              <%= new Date(a.created_at).toLocaleDateString('fr-FR', {
                day:   'numeric',
                month: 'long',
                year:  'numeric'
              }) %>
            </span>
          </div>
          <h3 class="news-home-card-title">
            <a href="/news/<%= a.id %>"><%= a.titre %></a>
          </h3>
          <div class="news-home-card-excerpt markdown-body">
            <%- a.contenuHtml %>
          </div>
          <a href="/news/<%= a.id %>" class="btn btn--ghost btn--sm news-read-more">
            Lire la suite <i class="fas fa-arrow-right"></i>
          </a>
        </article>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<%- include('partials/foot') %>

