<%- include('partials/head') %>

<!-- ═══════════════════ HERO ═══════════════════ -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="container hero-content">
    <div class="hero-badge">
      <span><i class="fas fa-bolt"></i> Association Gaming</span>
    </div>
    <h1 class="hero-title">
      Rejoignez la<br />
      <span class="text-gradient">LAN Party</span><br />
      ultime
    </h1>
    <p class="hero-subtitle">
      Compétitions, soirées gaming, tournois et bien plus encore.
      Rejoignez notre communauté de passionnés !
    </p>
    <div class="hero-actions">
      <% if (!currentUser) { %>
        <a href="/auth/register" class="btn btn--primary btn--lg">
          <i class="fas fa-user-plus"></i> Nous rejoindre
        </a>
        <a href="/auth/login" class="btn btn--ghost btn--lg">
          <i class="fas fa-right-to-bracket"></i> Connexion
        </a>
      <% } else { %>
        <a href="/profile" class="btn btn--primary btn--lg">
          <i class="fas fa-user"></i> Mon profil
        </a>
      <% } %>
    </div>
  </div>
  <div class="hero-scroll-indicator" aria-hidden="true">
    <i class="fas fa-chevron-down"></i>
  </div>
</section>

<!-- ═══════════════════ ÉVÉNEMENT ACTIF ═══════════════════ -->
<% if (activeEvent) { %>
<section class="section event-highlight-section">
  <div class="container">
    <div class="event-highlight-card">
      <div class="event-highlight-badge">
        <% const now = new Date(); const evDate = new Date(activeEvent.date_heure); %>
        <% if (evDate <= now) { %>
          <span class="event-status-badge event-status--live">
            <i class="fas fa-circle-play"></i> En cours
          </span>
        <% } else { %>
          <span class="event-status-badge event-status--upcoming">
            <i class="fas fa-calendar-check"></i> Prochain événement
          </span>
        <% } %>
      </div>

      <div class="event-highlight-body">
        <div class="event-highlight-info">
          <h2 class="event-highlight-title">
            <i class="fas fa-gamepad"></i> <%= activeEvent.nom %>
          </h2>
          <div class="event-highlight-meta">
            <span>
              <i class="fas fa-calendar-alt"></i>
              <%= new Date(activeEvent.date_heure).toLocaleDateString('fr-FR', {
                weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
              }) %>
              à
              <%= new Date(activeEvent.date_heure).toLocaleTimeString('fr-FR', {
                hour: '2-digit', minute: '2-digit'
              }) %>
            </span>
            <span>
              <i class="fas fa-location-dot"></i> <%= activeEvent.lieu %>
            </span>
            <span>
              <i class="fas fa-users"></i> <%= registrationCount %> inscrit<%= registrationCount !== 1 ? 's' : '' %>
            </span>
          </div>

          <!-- Chrono inscriptions -->
          <% if (registrationOpen) { %>
            <div class="event-countdown-wrap">
              <p class="event-countdown-label">
                <i class="fas fa-hourglass-half"></i> Inscriptions ouvertes — fermeture dans :
              </p>
              <div class="event-countdown" id="eventCountdown"
                   data-deadline="<%= new Date(new Date(activeEvent.date_heure).getTime() - 24 * 60 * 60 * 1000).toISOString() %>">
                <div class="countdown-unit"><span class="countdown-num" id="cd-days">--</span><span class="countdown-lbl">jours</span></div>
                <span class="countdown-sep">:</span>
                <div class="countdown-unit"><span class="countdown-num" id="cd-hours">--</span><span class="countdown-lbl">heures</span></div>
                <span class="countdown-sep">:</span>
                <div class="countdown-unit"><span class="countdown-num" id="cd-minutes">--</span><span class="countdown-lbl">min</span></div>
                <span class="countdown-sep">:</span>
                <div class="countdown-unit"><span class="countdown-num" id="cd-seconds">--</span><span class="countdown-lbl">sec</span></div>
              </div>
            </div>
          <% } else { %>
            <p class="event-registrations-closed">
              <i class="fas fa-lock"></i> Les inscriptions sont closes.
            </p>
          <% } %>
        </div>

        <!-- Actions -->
        <div class="event-highlight-actions">
          <% if (!currentUser) { %>
            <a href="/auth/register" class="btn btn--primary">
              <i class="fas fa-user-plus"></i> Créer un compte pour s'inscrire
            </a>
          <% } else if (isRegistered) { %>
            <div class="event-registered-badge">
              <i class="fas fa-circle-check"></i> Vous êtes inscrit !
            </div>
            <% if (registrationOpen) { %>
              <form action="/profile/events/<%= activeEvent.id %>/unregister" method="POST">
                <input type="hidden" name="_csrf" value="<%= csrfToken() %>" />
                <button type="submit" class="btn btn--ghost btn--sm"
                        onclick="return confirm('Annuler votre inscription ?')">
                  <i class="fas fa-user-minus"></i> Se désinscrire
                </button>
              </form>
            <% } %>
          <% } else if (registrationOpen) { %>
            <form action="/profile/events/<%= activeEvent.id %>/register" method="POST">
              <input type="hidden" name="_csrf" value="<%= csrfToken() %>" />
              <button type="submit" class="btn btn--primary">
                <i class="fas fa-user-plus"></i> S'inscrire à l'événement
              </button>
            </form>
          <% } else { %>
            <p class="text-muted">
              <i class="fas fa-lock"></i> Inscriptions closes.
            </p>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
/* ── Compte à rebours inscriptions ── */
(function () {
  'use strict';
  const el = document.getElementById('eventCountdown');
  if (!el) return;

  const deadline = new Date(el.dataset.deadline).getTime();

  function pad(n) { return String(n).padStart(2, '0'); }

  function tick() {
    const diff = deadline - Date.now();
    if (diff <= 0) {
      el.innerHTML = '<span class="event-registrations-closed"><i class="fas fa-lock"></i> Inscriptions closes</span>';
      return;
    }
    const days    = Math.floor(diff / 86400000);
    const hours   = Math.floor((diff % 86400000) / 3600000);
    const minutes = Math.floor((diff % 3600000)  / 60000);
    const seconds = Math.floor((diff % 60000)    / 1000);

    document.getElementById('cd-days').textContent    = days;
    document.getElementById('cd-hours').textContent   = pad(hours);
    document.getElementById('cd-minutes').textContent = pad(minutes);
    document.getElementById('cd-seconds').textContent = pad(seconds);

    setTimeout(tick, 1000);
  }
  tick();
})();
</script>
<% } %>

<!-- ═══════════════════ FEATURES ═══════════════════ -->
<section class="section features-section">
  <div class="container">
    <h2 class="section-title text-center">
      Pourquoi nous rejoindre ?
    </h2>
    <div class="features-grid">
      <article class="feature-card">
        <div class="feature-icon">
          <i class="fas fa-trophy"></i>
        </div>
        <h3>Tournois</h3>
        <p>Participez à des tournois organisés régulièrement sur vos jeux favoris.</p>
      </article>

      <article class="feature-card">
        <div class="feature-icon">
          <i class="fas fa-users"></i>
        </div>
        <h3>Communauté</h3>
        <p>Rejoignez des centaines de gamers passionnés et faites-vous de nouveaux amis.</p>
      </article>

      <article class="feature-card">
        <div class="feature-icon">
          <i class="fas fa-calendar-days"></i>
        </div>
        <h3>Événements</h3>
        <p>LAN parties, soirées gaming et rassemblements tout au long de l'année.</p>
      </article>

      <article class="feature-card">
        <div class="feature-icon">
          <i class="fas fa-headset"></i>
        </div>
        <h3>Support</h3>
        <p>Une équipe dédiée pour vous accompagner dans tous vos besoins gaming.</p>
      </article>
    </div>
  </div>
</section>

<!-- ═══════════════════ CTA ═══════════════════ -->
<% if (!currentUser) { %>
<section class="section cta-section">
  <div class="container cta-inner">
    <div class="cta-content">
      <h2>Prêt à rejoindre l'aventure ?</h2>
      <p>Créez votre compte gratuitement et accédez à tous nos événements.</p>
    </div>
    <a href="/auth/register" class="btn btn--primary btn--lg">
      <i class="fas fa-gamepad"></i> Commencer maintenant
    </a>
  </div>
</section>
<% } %>

<!-- ═══════════════════ DERNIÈRES ANNONCES ═══════════════════ -->
<% if (latestAnnouncements && latestAnnouncements.length > 0) { %>
<section class="section news-home-section">
  <div class="container">
    <div class="news-home-header">
      <h2 class="section-title">
        <i class="fas fa-newspaper"></i> Dernières actualités
      </h2>
      <a href="/news" class="btn btn--ghost btn--sm news-all-link">
        Toutes les actualités <i class="fas fa-arrow-right"></i>
      </a>
    </div>
    <div class="news-home-grid">
      <% latestAnnouncements.forEach(function(a) { %>
        <article class="news-home-card">
          <div class="news-card-meta">
            <span class="news-card-date">
              <i class="fas fa-calendar-alt"></i>
              <%= new Date(a.created_at).toLocaleDateString('fr-FR', {
                day:   'numeric',
                month: 'long',
                year:  'numeric'
              }) %>
            </span>
          </div>
          <h3 class="news-home-card-title">
            <a href="/news/<%= a.id %>"><%= a.titre %></a>
          </h3>
          <div class="news-home-card-excerpt markdown-body">
            <%- a.contenuHtml %>
          </div>
          <a href="/news/<%= a.id %>" class="btn btn--ghost btn--sm news-read-more">
            Lire la suite <i class="fas fa-arrow-right"></i>
          </a>
        </article>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<%- include('partials/foot') %>

