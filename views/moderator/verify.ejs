<%- include('../partials/head') %>

<style>
  @media (max-width: 768px) {
    .verify-container {
      padding-top: var(--space-md) !important;
      padding-left: var(--space-sm) !important;
      padding-right: var(--space-sm) !important;
    }

    .verify-container .admin-title {
      font-size: 1.25rem;
    }

    .verify-container .card-body {
      padding: var(--space-md);
    }

    .verify-container .verify-event-name,
    .verify-container .verify-player-pseudo {
      word-break: break-word;
    }
  }
</style>

<div class="container verify-container" style="max-width: 600px; padding-top: var(--space-xl);">

  <div class="admin-header">
    <div>
      <h1 class="admin-title">
        <i class="fas fa-id-card"></i> Vérification de badge
      </h1>
    </div>
    <div class="admin-header-actions">
      <a href="<%= returnTo || '/moderator' %>" class="btn btn--ghost btn--sm">
        <i class="fas fa-arrow-left"></i> Retour
      </a>
    </div>
  </div>

  <% if (error) { %>
    <!-- Erreur technique -->
    <div class="card" style="border: 2px solid var(--color-danger); margin-bottom: var(--space-lg);">
      <div class="card-body" style="text-align: center; padding: var(--space-xl);">
        <div style="font-size: 4rem; color: var(--color-danger); margin-bottom: var(--space-md);">
          <i class="fas fa-circle-xmark"></i>
        </div>
        <h2 style="color: var(--color-danger); margin-bottom: var(--space-sm);">Badge invalide</h2>
        <p class="text-muted"><%= error %></p>
        <% if (token) { %>
          <p class="text-muted" style="font-family: monospace; font-size: 0.8rem; margin-top: var(--space-sm);">
            Token : <%= token %>
          </p>
        <% } %>
      </div>
    </div>

  <% } else if (!member) { %>
    <!-- Badge inconnu -->
    <div class="card" style="border: 2px solid var(--color-danger); margin-bottom: var(--space-lg);">
      <div class="card-body" style="text-align: center; padding: var(--space-xl);">
        <div style="font-size: 4rem; color: var(--color-danger); margin-bottom: var(--space-md);">
          <i class="fas fa-circle-xmark"></i>
        </div>
        <h2 style="color: var(--color-danger); margin-bottom: var(--space-sm);">Badge inconnu</h2>
        <p class="text-muted">Ce badge n'appartient à aucun membre de l'association.</p>
        <% if (token) { %>
          <p class="text-muted" style="font-family: monospace; font-size: 0.8rem; margin-top: var(--space-sm);">
            Token : <%= token %>
          </p>
        <% } %>
      </div>
    </div>

  <% } else { %>
    <% const cardColor = (event && isRegistered) ? 'var(--color-success)' : event ? 'var(--color-danger)' : 'var(--color-primary)'; %>
    <!-- Membre trouvé -->
    <div class="card" style="border: 2px solid <%= cardColor %>; margin-bottom: var(--space-lg);">
      <div class="card-header" style="background: color-mix(in srgb, <%= cardColor %> 10%, transparent); border-bottom: 1px solid <%= cardColor %>;">
        <div style="display:flex; align-items:center; gap: var(--space-sm);">
          <span style="font-size: 2rem; color: <%= cardColor %>;"><i class="fas fa-circle-user"></i></span>
          <div>
            <h2 style="color: <%= cardColor %>; margin:0;">Membre identifié</h2>
            <p style="margin:0; font-size: 0.85rem; color: var(--color-text-muted);">
              Badge de membre authentique
            </p>
          </div>
        </div>
      </div>
      <div class="card-body">

        <!-- Infos membre -->
        <div class="verify-section">
          <h3 class="verify-section-title"><i class="fas fa-user"></i> Membre</h3>
          <p class="verify-player-pseudo"><%= member.pseudo %></p>
          <p class="verify-detail"><%= member.prenom %> <%= member.nom %></p>
          <p class="verify-detail"><a href="mailto:<%= member.email %>" class="link-muted"><%= member.email %></a></p>
          <div style="margin-top: var(--space-xs);">
            <% if (member.is_admin) { %>
              <span class="badge badge--admin"><i class="fas fa-shield-halved"></i> Administrateur</span>
            <% } else if (member.is_moderator) { %>
              <span class="badge badge--moderator"><i class="fas fa-user-shield"></i> Modérateur</span>
            <% } else { %>
              <span class="badge badge--member"><i class="fas fa-user"></i> Membre</span>
            <% } %>
          </div>
        </div>

        <% if (event) { %>
          <hr style="border-color: var(--color-border); margin: var(--space-md) 0;" />

          <!-- Statut inscription à l'événement -->
          <div class="verify-section">
            <h3 class="verify-section-title"><i class="fas fa-calendar-star"></i> Événement contrôlé</h3>
            <p class="verify-event-name"><%= event.nom %></p>
            <p class="verify-detail">
              <i class="fas fa-calendar-alt"></i>
              <%= new Date(event.date_heure).toLocaleDateString('fr-FR', {
                weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
              }) %>
              à
              <%= new Date(event.date_heure).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' }) %>
            </p>
            <p class="verify-detail"><i class="fas fa-location-dot"></i> <%= event.lieu %></p>

            <div style="margin-top: var(--space-md); padding: var(--space-md); border-radius: var(--radius-md);
                        background: color-mix(in srgb, <%= cardColor %> 10%, transparent);
                        border: 1px solid <%= cardColor %>;">
              <% if (isRegistered) { %>
                <p style="color: var(--color-success); font-size: 1.05rem; font-weight: 600; margin: 0;">
                  <i class="fas fa-circle-check"></i> Inscrit à cet événement
                </p>
                <p style="color: var(--color-text-muted); font-size: 0.85rem; margin: var(--space-xs) 0 0;">
                  L'accès est autorisé.
                </p>
              <% } else { %>
                <p style="color: var(--color-danger); font-size: 1.05rem; font-weight: 600; margin: 0;">
                  <i class="fas fa-circle-xmark"></i> Non inscrit à cet événement
                </p>
                <p style="color: var(--color-text-muted); font-size: 0.85rem; margin: var(--space-xs) 0 0;">
                  Ce membre ne figure pas dans la liste des inscrits.
                </p>
              <% } %>
            </div>
          </div>
        <% } else { %>
          <hr style="border-color: var(--color-border); margin: var(--space-md) 0;" />
          <p class="text-muted" style="font-size: 0.9rem;">
            <i class="fas fa-circle-info"></i>
            Aucun événement associé à cette vérification.
            Utilisez le scanner depuis la page de contrôle d'un événement spécifique.
          </p>
        <% } %>

      </div>
    </div>

  <% } %>

</div>

<%- include('../partials/foot') %>
