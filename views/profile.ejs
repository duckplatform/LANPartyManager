<%- include('partials/head') %>

<div class="profile-container container">
  <div class="profile-header">
    <div class="profile-avatar">
      <i class="fas fa-circle-user"></i>
    </div>
    <div class="profile-info">
      <h1 class="profile-name"><%= user.pseudo %></h1>
      <p class="profile-meta"><%= user.prenom %> <%= user.nom %></p>
      <% if (user.is_admin) { %>
        <span class="badge badge--admin"><i class="fas fa-shield-halved"></i> Administrateur</span>
      <% } else if (user.is_moderator) { %>
        <span class="badge badge--moderator"><i class="fas fa-user-shield"></i> Modérateur</span>
      <% } else { %>
        <span class="badge badge--member"><i class="fas fa-user"></i> Membre</span>
      <% } %>
    </div>
  </div>

  <!-- Onglets -->
  <div class="profile-tabs" role="tablist">
    <button class="tab-btn<%= (typeof activeTab === 'undefined' || activeTab === 'info') ? ' active' : '' %>"
            role="tab" data-tab="tab-info" aria-selected="<%= (typeof activeTab === 'undefined' || activeTab === 'info') ? 'true' : 'false' %>">
      <i class="fas fa-user-pen"></i> Informations
    </button>
    <button class="tab-btn<%= (typeof activeTab !== 'undefined' && activeTab === 'password') ? ' active' : '' %>"
            role="tab" data-tab="tab-password" aria-selected="<%= (typeof activeTab !== 'undefined' && activeTab === 'password') ? 'true' : 'false' %>">
      <i class="fas fa-key"></i> Mot de passe
    </button>
    <button class="tab-btn<%= (typeof activeTab !== 'undefined' && activeTab === 'events') ? ' active' : '' %>"
            role="tab" data-tab="tab-events" aria-selected="<%= (typeof activeTab !== 'undefined' && activeTab === 'events') ? 'true' : 'false' %>">
      <i class="fas fa-calendar-days"></i> Événements
    </button>
    <button class="tab-btn<%= (typeof activeTab !== 'undefined' && activeTab === 'badge') ? ' active' : '' %>"
            role="tab" data-tab="tab-badge" aria-selected="<%= (typeof activeTab !== 'undefined' && activeTab === 'badge') ? 'true' : 'false' %>">
      <i class="fas fa-id-card"></i> Mon badge
    </button>
  </div>

  <!-- Erreurs de validation -->
  <% if (errors && errors.length > 0) { %>
    <div class="form-errors" role="alert">
      <% errors.forEach(function(err) { %>
        <p class="form-error-msg"><i class="fas fa-triangle-exclamation"></i> <%= err.msg %></p>
      <% }); %>
    </div>
  <% } %>

  <!-- Panneau : Informations -->
  <div id="tab-info" class="tab-panel<%= (typeof activeTab === 'undefined' || activeTab === 'info') ? ' active' : '' %>" role="tabpanel">
    <div class="card">
      <div class="card-header">
        <h2><i class="fas fa-user-pen"></i> Modifier mes informations</h2>
      </div>
      <div class="card-body">
        <form action="/profile" method="POST" class="profile-form" novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken() %>" />

          <div class="form-row">
            <div class="form-group">
              <label for="nom" class="form-label">Nom</label>
              <input type="text" id="nom" name="nom" class="form-input"
                     value="<%= user.nom || '' %>" required maxlength="100" />
            </div>
            <div class="form-group">
              <label for="prenom" class="form-label">Prénom</label>
              <input type="text" id="prenom" name="prenom" class="form-input"
                     value="<%= user.prenom || '' %>" required maxlength="100" />
            </div>
          </div>

          <div class="form-group">
            <label for="pseudo" class="form-label">
              <i class="fas fa-gamepad"></i> Pseudo (jeu ou Discord)
            </label>
            <input type="text" id="pseudo" name="pseudo" class="form-input"
                   value="<%= user.pseudo || '' %>" required minlength="2" maxlength="50" />
            <small class="form-hint">Ce pseudo est utilise pour identifier les joueurs dans les annonces de rencontres Discord.</small>
          </div>

          <div class="form-group">
            <label for="email" class="form-label">
              <i class="fas fa-envelope"></i> Adresse e-mail
            </label>
            <input type="email" id="email" name="email" class="form-input"
                   value="<%= user.email || '' %>" required autocomplete="email" />
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn--primary">
              <i class="fas fa-floppy-disk"></i> Sauvegarder
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Panneau : Mot de passe -->
  <div id="tab-password" class="tab-panel<%= (typeof activeTab !== 'undefined' && activeTab === 'password') ? ' active' : '' %>" role="tabpanel">
    <div class="card">
      <div class="card-header">
        <h2><i class="fas fa-key"></i> Changer mon mot de passe</h2>
      </div>
      <div class="card-body">
        <form action="/profile/password" method="POST" class="profile-form" novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken() %>" />

          <div class="form-group">
            <label for="current_password" class="form-label">Mot de passe actuel</label>
            <div class="input-password-wrap">
              <input type="password" id="current_password" name="current_password"
                     class="form-input" placeholder="••••••••" required autocomplete="current-password" />
              <button type="button" class="password-toggle" aria-label="Afficher/masquer">
                <i class="fas fa-eye"></i>
              </button>
            </div>
          </div>

          <div class="form-group">
            <label for="new_password" class="form-label">Nouveau mot de passe</label>
            <div class="input-password-wrap">
              <input type="password" id="new_password" name="new_password"
                     class="form-input" placeholder="••••••••" required minlength="8"
                     autocomplete="new-password" />
              <button type="button" class="password-toggle" aria-label="Afficher/masquer">
                <i class="fas fa-eye"></i>
              </button>
            </div>
            <small class="form-hint">Minimum 8 caractères, une majuscule et un chiffre.</small>
          </div>

          <div class="form-group">
            <label for="new_password_confirm" class="form-label">Confirmer le nouveau mot de passe</label>
            <div class="input-password-wrap">
              <input type="password" id="new_password_confirm" name="new_password_confirm"
                     class="form-input" placeholder="••••••••" required autocomplete="new-password" />
              <button type="button" class="password-toggle" aria-label="Afficher/masquer">
                <i class="fas fa-eye"></i>
              </button>
            </div>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn--primary">
              <i class="fas fa-key"></i> Changer le mot de passe
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Panneau : Événements -->
  <div id="tab-events" class="tab-panel<%= (typeof activeTab !== 'undefined' && activeTab === 'events') ? ' active' : '' %>" role="tabpanel">

    <!-- Événement à venir ou en cours -->
    <% if (activeEvent) { %>
    <div class="card" style="margin-bottom: var(--space-md);">
      <div class="card-header">
        <h2><i class="fas fa-calendar-star"></i> Prochain événement</h2>
      </div>
      <div class="card-body">
        <h3 style="margin-bottom: var(--space-sm);"><%= activeEvent.nom %></h3>
        <p>
          <i class="fas fa-calendar-alt"></i>
          <%= new Date(activeEvent.date_heure).toLocaleDateString('fr-FR', {
            weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
          }) %>
          à
          <%= new Date(activeEvent.date_heure).toLocaleTimeString('fr-FR', {
            hour: '2-digit', minute: '2-digit'
          }) %>
        </p>
        <p><i class="fas fa-location-dot"></i> <%= activeEvent.lieu %></p>

        <% if (isRegistered) { %>
          <div class="event-registered-badge" style="margin: var(--space-md) 0;">
            <i class="fas fa-circle-check"></i> Vous êtes inscrit à cet événement !
          </div>
          <!-- Bouton d'accès au badge électronique -->
          <div style="margin-bottom: var(--space-md);">
            <a href="/profile/events/<%= activeEvent.id %>/badge" class="btn btn--primary btn--sm">
              <i class="fas fa-ticket"></i> Voir mon badge électronique
            </a>
          </div>
          <% if (registrationOpen) { %>
            <form action="/profile/events/<%= activeEvent.id %>/unregister" method="POST">
              <input type="hidden" name="_csrf" value="<%= csrfToken() %>" />
              <button type="submit" class="btn btn--ghost btn--sm"
                      onclick="return confirm('Annuler votre inscription à cet événement ?')">
                <i class="fas fa-user-minus"></i> Annuler mon inscription
              </button>
            </form>
          <% } else { %>
            <p class="form-hint"><i class="fas fa-lock"></i> Les inscriptions sont closes (l'événement a déjà commencé ou n'est plus disponible).</p>
          <% } %>
        <% } else if (registrationOpen) { %>
          <form action="/profile/events/<%= activeEvent.id %>/register" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken() %>" />
            <button type="submit" class="btn btn--primary">
              <i class="fas fa-user-plus"></i> S'inscrire à cet événement
            </button>
          </form>
        <% } else { %>
          <p class="form-hint"><i class="fas fa-lock"></i> Les inscriptions sont closes (l'événement a déjà commencé ou n'est plus disponible).</p>
        <% } %>
      </div>
    </div>
    <% } else { %>
    <div class="card" style="margin-bottom: var(--space-md);">
      <div class="card-body">
        <p class="text-muted text-center">
          <i class="fas fa-calendar-xmark"></i> Aucun événement en cours ou à venir pour le moment.
        </p>
      </div>
    </div>
    <% } %>

    <!-- Historique des inscriptions -->
    <div class="card">
      <div class="card-header">
        <h2><i class="fas fa-history"></i> Mes inscriptions</h2>
      </div>
      <div class="card-body">
        <% if (!userRegistrations || userRegistrations.length === 0) { %>
          <p class="text-muted text-center">
            <i class="fas fa-inbox"></i> Vous n'êtes inscrit à aucun événement.
          </p>
        <% } else { %>
          <div class="table-responsive">
            <table class="data-table">
              <thead>
                <tr>
                  <th>Événement</th>
                  <th>Date</th>
                  <th>Lieu</th>
                  <th>Statut</th>
                  <th>Inscrit le</th>
                </tr>
              </thead>
              <tbody>
                <% userRegistrations.forEach(function(r) { %>
                  <tr>
                    <td><strong><%= r.nom %></strong></td>
                    <td class="td-date">
                      <%= new Date(r.date_heure).toLocaleDateString('fr-FR', {
                        day: '2-digit', month: '2-digit', year: 'numeric'
                      }) %>
                    </td>
                    <td><%= r.lieu %></td>
                    <td>
                      <% if (r.statut === 'planifie') { %>
                        <span class="badge badge--admin"><i class="fas fa-calendar-check"></i> Planifié</span>
                      <% } else if (r.statut === 'en_cours') { %>
                        <span class="badge badge--member"><i class="fas fa-circle-play"></i> En cours</span>
                      <% } else { %>
                        <span class="badge badge--draft"><i class="fas fa-circle-check"></i> Terminé</span>
                      <% } %>
                    </td>
                    <td class="td-date">
                      <%= new Date(r.created_at).toLocaleDateString('fr-FR') %>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
    </div>

  </div>

  <!-- Panneau : Badge de membre -->
  <div id="tab-badge" class="tab-panel<%= (typeof activeTab !== 'undefined' && activeTab === 'badge') ? ' active' : '' %>" role="tabpanel">
    <div class="card">
      <div class="card-header">
        <h2><i class="fas fa-id-card"></i> Mon badge de membre</h2>
      </div>
      <div class="card-body" style="text-align: center; padding: var(--space-xl);">
        <p class="form-hint" style="margin-bottom: var(--space-lg);">
          <i class="fas fa-circle-info"></i>
          Votre badge de membre contient un QR code unique et personnel.
          Présentez-le à l'entrée de chaque événement auquel vous êtes inscrit.
        </p>
        <div style="display: flex; gap: var(--space-sm); justify-content: center; flex-wrap: wrap;">
          <a href="/profile/badge" class="btn btn--primary">
            <i class="fas fa-id-card"></i> Voir mon badge
          </a>
          <a href="/profile/badge" target="_blank" class="btn btn--ghost">
            <i class="fas fa-external-link-alt"></i> Ouvrir dans un nouvel onglet
          </a>
        </div>
        <p class="form-hint" style="margin-top: var(--space-md);">
          <i class="fas fa-print"></i> Imprimez ou sauvegardez en PDF depuis la page du badge.
        </p>
      </div>
    </div>
  </div>

  <!-- Infos compte -->
  <div class="card profile-meta-card">
    <div class="card-body profile-meta-info">
      <div class="meta-item">
        <span class="meta-label"><i class="fas fa-calendar-plus"></i> Membre depuis</span>
        <span class="meta-value"><%= new Date(user.created_at).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
      </div>
      <% if (user.updated_at) { %>
      <div class="meta-item">
        <span class="meta-label"><i class="fas fa-pen-to-square"></i> Dernière modification</span>
        <span class="meta-value"><%= new Date(user.updated_at).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
      </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('partials/foot') %>
