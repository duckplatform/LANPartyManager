<footer class="site-footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="logo logo--sm">
          <% if (appSettings.organization_logo) { %>
            <img src="<%= appSettings.organization_logo %>" alt="Logo" style="max-height: 30px; max-width: 150px;" />
          <% } else { %>
            <span class="logo-icon"><i class="fas fa-gamepad"></i></span>
          <% } %>
          <span class="logo-text"><%= appSettings.organization_name %></span>
        </a>
        <% if (appSettings.organization_slogan) { %>
          <p class="footer-tagline"><%= appSettings.organization_slogan %></p>
        <% } %>
      </div>

      <nav class="footer-nav" aria-label="Navigation pied de page">
        <h3 class="footer-nav-title">Navigation</h3>
        <ul>
          <li><a href="/">Accueil</a></li>
          <li><a href="/news">Actualités</a></li>
          <% if (currentUser) { %>
            <li><a href="/profile">Mon profil</a></li>
            <% if (currentUser.isAdmin) { %>
              <li><a href="/admin">Administration</a></li>
            <% } %>
          <% } else { %>
            <li><a href="/auth/login">Connexion</a></li>
            <li><a href="/auth/register">Inscription</a></li>
          <% } %>
        </ul>
      </nav>

      <div class="footer-social">
        <h3 class="footer-nav-title">Communauté</h3>
        <div class="social-links">
          <% if (appSettings.community_link_discord) { %>
            <a href="<%= appSettings.community_link_discord %>" class="social-link" aria-label="Discord" target="_blank" rel="noopener noreferrer"><i class="fab fa-discord"></i></a>
          <% } %>
          <% if (appSettings.community_link_twitch) { %>
            <a href="<%= appSettings.community_link_twitch %>" class="social-link" aria-label="Twitch" target="_blank" rel="noopener noreferrer"><i class="fab fa-twitch"></i></a>
          <% } %>
          <% if (appSettings.community_link_twitter) { %>
            <a href="<%= appSettings.community_link_twitter %>" class="social-link" aria-label="Twitter / X" target="_blank" rel="noopener noreferrer"><i class="fab fa-x-twitter"></i></a>
          <% } %>
          <% if (appSettings.community_link_youtube) { %>
            <a href="<%= appSettings.community_link_youtube %>" class="social-link" aria-label="YouTube" target="_blank" rel="noopener noreferrer"><i class="fab fa-youtube"></i></a>
          <% } %>
          <% if (appSettings.community_link_website) { %>
            <a href="<%= appSettings.community_link_website %>" class="social-link" aria-label="Site web" target="_blank" rel="noopener noreferrer"><i class="fas fa-globe"></i></a>
          <% } %>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; <%= new Date().getFullYear() %> <%= appSettings.organization_name %>. Tous droits réservés.</p>
    </div>
  </div>
</footer>
